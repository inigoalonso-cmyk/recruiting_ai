# --- HappyRobot workflow (the search "brain") ---
# The app POSTs { query, criteria, limit, candidates, requestId, callbackUrl } here.
# The workflow ranks and POSTs { requestId, selected_ids } back to callbackUrl.
# Leave EMPTY to use the local fallback ranking (UI works without it).
HAPPYROBOT_WEBHOOK_URL=
HAPPYROBOT_WEBHOOK_SECRET=

# Public URL of THIS app, so the workflow's callback can reach it.
# On Railway set it to your deployed URL, e.g. https://recruitingai-production-98b0.up.railway.app
# If left empty, the app derives it from the request headers (usually fine on Railway).
APP_BASE_URL=

# --- Online discovery ("Discover online" search mode) ---
# SerpAPI key used by POST /api/discover to find public professional profiles.
# Get one at https://serpapi.com. If empty, the "Discover online" mode returns an error.
SERPAPI_KEY=

# --- Embeddings (optional, only improves the local narrowing step) ---
# If set, the app narrows the pool with embeddings before sending to the workflow.
# If empty, it narrows with a lightweight keyword match (no API key needed).
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
