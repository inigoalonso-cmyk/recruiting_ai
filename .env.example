# --- HappyRobot workflow (the search "brain") ---
# The app POSTs { query, criteria, limit, candidates:[...] } here and the workflow
# returns the top N. Leave EMPTY to use the local fallback ranking (UI works without it).
HAPPYROBOT_WEBHOOK_URL=
HAPPYROBOT_WEBHOOK_SECRET=

# --- Embeddings (optional, only improves the local narrowing step) ---
# If set, the app narrows the pool with embeddings before sending to the workflow.
# If empty, it narrows with a lightweight keyword match (no API key needed).
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
